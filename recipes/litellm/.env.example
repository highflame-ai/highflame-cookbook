# Copy to .env and fill in. Never commit the real file.

# --- Highflame (prod / SaaS defaults) ---
HIGHFLAME_API_KEY=hf_sk_replace_me                 # tenant key: Studio -> Settings -> API Keys
HIGHFLAME_GATEWAY_URL=https://gateway.highflame.ai/v1   # Firehog, OpenAI-compatible
HIGHFLAME_BASE_URL=https://api.highflame.ai             # Shield/SDK base (guard at /v1/shield/guard)

# --- Your existing provider key(s) (used by LiteLLM, passed through Firehog) ---
OPENAI_API_KEY=sk-replace_me
# ANTHROPIC_API_KEY=sk-ant-replace_me

# --- To target dev1 instead of prod, override:
# HIGHFLAME_GATEWAY_URL=https://gateway-dev.highflame.dev/v1
# HIGHFLAME_BASE_URL=https://api-dev.highflame.dev
