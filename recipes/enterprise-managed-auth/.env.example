# Copy to .env and fill in. Never commit the real file.

# Base URL of your Highflame MCP gateway — the host that serves
# /.well-known/oauth-protected-resource. smoke_test.py fetches that document and
# confirms Enterprise-Managed Authorization is advertised on your endpoint.
# (Adjust the path to match your gateway; this is the default SaaS shape.)
HIGHFLAME_MCP_RESOURCE_URL=https://gateway.highflame.ai/v1/ai-gateway
