# The Aperture service key from Studio -> Code Agents -> Tailscale Aperture.
HIGHFLAME_API_KEY=

# Optional: override the Cerberus Aperture hook endpoint (defaults to prod).
# HIGHFLAME_APERTURE_ENDPOINT=https://api.highflame.ai/v1/cerberus/agent/events

# Optional: the developer login this request is attributed to (defaults to
# developer@example.com). With Highflame's identity gate enabled, set this to your own
# Highflame login email — the SAME email you use for Tailscale — or the request is denied
# as a non-member. See ../README.md#identity--access.
# HIGHFLAME_APERTURE_LOGIN=you@yourco.com
