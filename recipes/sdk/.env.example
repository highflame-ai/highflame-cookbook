# Highflame API key — generate in Studio → Settings → API Keys
# Format: hf_sk_<random>
HIGHFLAME_API_KEY=hf_sk_your_key_here

# Base URL of the Shield service.
# SaaS (default): https://api.highflame.ai
# Self-hosted / local dev: http://localhost:8080
HIGHFLAME_BASE_URL=https://api.highflame.ai

# Optional: Your LLM provider key (used in the agentic session examples)
OPENAI_API_KEY=sk-...
